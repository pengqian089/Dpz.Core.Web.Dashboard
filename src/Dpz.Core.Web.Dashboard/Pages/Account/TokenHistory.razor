@using Dpz.Core.Web.Dashboard.Shared.Components

<div class="account-token">
    <div class="account-token__header">
        <div class="account-token__title">
            <i class="fas fa-shield-alt"></i>
            登录记录
        </div>
        <div class="account-token__subtitle">
            账号：@Account
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="account-token__skeleton">
            @for (var i = 0; i < 5; i++)
            {
                <div class="account-token__skeleton-row">
                    <div class="skeleton skeleton--text"></div>
                    <div class="skeleton skeleton--text"></div>
                    <div class="skeleton skeleton--text-lg"></div>
                    <div class="skeleton skeleton--text"></div>
                    <div class="skeleton skeleton--text"></div>
                    <div class="skeleton skeleton--text"></div>
                    <div class="skeleton skeleton--text"></div>
                </div>
            }
        </div>
    }
    else if (_records.Count == 0)
    {
        <div class="account-token__empty">
            <i class="fas fa-history"></i>
            暂无登录记录
        </div>
    }
    else
    {
        <div class="account-token__table">
            <div class="account-token__table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>账号</th>
                            <th>IP地址</th>
                            <th>User-Agent</th>
                            <th>SessionId</th>
                            <th>登录方式</th>
                            <th>登录结果</th>
                            <th>创建时间</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in _records)
                        {
                            <tr>
                                <td data-label="账号">@record.Account</td>
                                <td data-label="IP地址">@record.IpAddress</td>
                                <td data-label="User-Agent">
                                    <span class="account-token__agent" title="@record.UserAgent">
                                        @record.UserAgent
                                    </span>
                                </td>
                                <td data-label="SessionId">
                                    <span class="account-token__session">@record.SessionId</span>
                                </td>
                                <td data-label="登录方式">@record.MethodStr</td>
                                <td data-label="登录结果">
                                    <span class="account-token__status @GetStatusClass(record.Status)">
                                        @record.StatusStr
                                    </span>
                                </td>
                                <td data-label="创建时间">
                                    @record.CreateTime.ToString("yyyy-MM-dd HH:mm:ss")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <Pagination CurrentPage="_pageIndex"
                        TotalPages="_totalPages"
                        TotalCount="_totalCount"
                        PageSize="PageSize"
                        OnPageChanged="HandlePageChanged"/>
        </div>
    }

    <div class="account-token__footer">
        <button class="btn btn-secondary" @onclick="Close">关闭</button>
    </div>
</div>