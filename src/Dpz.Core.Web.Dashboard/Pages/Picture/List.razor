@page "/picture"
@page "/picture/list"
@attribute [Authorize]
@using Dpz.Core.Web.Dashboard.Shared.Components

<div class="picture-list">
    <div class="picture-list__header">
        <h1 class="page-title">图片管理</h1>
        <p class="page-description">管理和维护网站的所有图片资源</p>
    </div>

    <div class="picture-list__toolbar">
        <div class="picture-list__toolbar-left">
            <button class="btn btn-primary" @onclick="PostPicture">
                <i class="fas fa-upload"></i>
                上传图片
            </button>

            <div class="picture-list__view-toggle">
                <button class="view-toggle-btn @(_viewMode == "grid" ? "view-toggle-btn--active" : "")"
                        @onclick='() => ToggleViewMode("grid")'
                        title="网格视图">
                    <i class="fas fa-th"></i>
                </button>
                <button class="view-toggle-btn @(_viewMode == "table" ? "view-toggle-btn--active" : "")"
                        @onclick='() => ToggleViewMode("table")'
                        title="表格视图">
                    <i class="fas fa-list"></i>
                </button>
            </div>
        </div>

        <div class="picture-list__toolbar-right">
            <select class="form-control form-select" @bind="_tag" @bind:after="Search">
                <option value="">全部标签</option>
                @foreach (var item in _tags)
                {
                    <option value="@item">@item</option>
                }
            </select>

            <select class="form-control form-select" @bind="_pictureType" @bind:after="Search">
                <option value="-1">全部类型</option>
                @foreach (var item in AppTools.PictureTypes)
                {
                    <option value="@item.Key">@item.Value</option>
                }
            </select>

            <input type="text"
                   class="form-control"
                   placeholder="搜索描述..."
                   @bind="_description"
                   @bind:event="oninput"
                   @onkeydown="@(async e => { if (e.Key == "Enter") await Search(); })" />

            <button class="btn btn-primary" @onclick="Search">
                <i class="fas fa-search"></i>
                搜索
            </button>
        </div>
    </div>

    @if (_isLoading)
    {
        @if (_viewMode == "grid")
        {
            <div class="picture-grid-skeleton">
                @for (var i = 0; i < 12; i++)
                {
                    <div class="picture-card-skeleton">
                        <div class="picture-card-skeleton__image skeleton skeleton--full"></div>
                        <div class="picture-card-skeleton__content">
                            <div class="skeleton skeleton--text-lg skeleton--full"></div>
                            <div class="skeleton skeleton--text skeleton--full"></div>
                            <div class="skeleton skeleton--text skeleton--half"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="article-list-skeleton">
                <div class="article-list-skeleton__table">
                    @for (var i = 0; i < 12; i++)
                    {
                        <div class="article-list-skeleton__row">
                            <div class="skeleton skeleton--avatar"></div>
                            <div class="skeleton skeleton--text-lg"></div>
                            <div class="skeleton skeleton--text"></div>
                            <div class="skeleton skeleton--text"></div>
                            <div class="skeleton skeleton--text"></div>
                            <div class="skeleton skeleton--text"></div>
                            <div class="skeleton skeleton--text"></div>
                            <div class="skeleton skeleton--button"></div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else if (_pictures.Count == 0)
    {
        <div class="picture-list__empty">
            <i class="fas fa-image fa-3x" style="margin-bottom: var(--spacing-md); opacity: 0.3;"></i>
            <p>暂无图片数据</p>
        </div>
    }
    else
    {
        @if (_viewMode == "grid")
        {
            <div class="picture-grid">
                @foreach (var picture in _pictures)
                {
                    <div class="picture-card">
                        <div class="picture-card__image">
                            <img src="@(picture.AccessUrl + "!albums")" alt="@picture.Description" loading="lazy" />
                            <span class="picture-card__type">@picture.Category</span>
                        </div>
                        <div class="picture-card__content">
                            <div class="picture-card__description">@picture.Description</div>

                            <div class="picture-card__meta">
                                <div class="picture-card__meta-item">
                                    <i class="fas fa-user"></i>
                                    <span>@picture.Creator?.Name</span>
                                </div>
                                <div class="picture-card__meta-item">
                                    <i class="fas fa-calendar"></i>
                                    <span>@picture.UploadTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                </div>
                                <div class="picture-card__meta-item">
                                    <i class="fas fa-expand-arrows-alt"></i>
                                    <span>@(picture.Width) × @(picture.Height)</span>
                                </div>
                                <div class="picture-card__meta-item">
                                    <i class="fas fa-file"></i>
                                    <span>@picture.Length.FileSize()</span>
                                </div>
                                <div class="picture-card__meta-item">
                                    <i class="fas fa-fingerprint "></i>
                                    <span>@picture.Md5</span>
                                </div>
                            </div>

                            @if (picture.Tags.Any())
                            {
                                <div class="picture-card__tags">
                                    @foreach (var tag in picture.Tags)
                                    {
                                        <span class="picture-card__tag">@tag</span>
                                    }
                                </div>
                            }

                            <div class="picture-card__footer">
                                <div class="picture-card__actions">
                                    <button class="btn btn-primary btn-sm" @onclick="() => EditPicture(picture.Id)">
                                        <i class="fas fa-edit"></i>
                                        编辑
                                    </button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteAsync(picture.Id)">
                                        <i class="fas fa-trash"></i>
                                        删除
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="picture-table">
                <div class="picture-table__wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>预览</th>
                                <th>描述</th>
                                <th>标签</th>
                                <th>上传人</th>
                                <th>上传时间</th>
                                <th>类型</th>
                                <th>尺寸</th>
                                <th>大小</th>
                                <th>MD5</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var picture in _pictures)
                            {
                                <tr>
                                    <td data-label="预览">
                                        <img src="@(picture.AccessUrl + "!albums")" alt="@picture.Description" class="picture-table__thumbnail" loading="lazy" />
                                    </td>
                                    <td data-label="描述">
                                        <div class="picture-table__description" title="@picture.Description">
                                            @picture.Description
                                        </div>
                                    </td>
                                    <td data-label="标签">
                                        <div class="picture-table__tags">
                                            @foreach (var tag in picture.Tags)
                                            {
                                                <span class="picture-table__tag">@tag</span>
                                            }
                                        </div>
                                    </td>
                                    <td data-label="上传人">@picture.Creator?.Name</td>
                                    <td data-label="上传时间">@picture.UploadTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td data-label="类型">@picture.Category</td>
                                    <td data-label="尺寸">@(picture.Width) × @(picture.Height)</td>
                                    <td data-label="大小">@picture.Length.FileSize()</td>
                                    <td data-label="MD5">@picture.Md5</td>
                                    <td data-label="操作">
                                        <div class="picture-table__actions">
                                            <button class="btn btn-primary btn-sm" @onclick="() => EditPicture(picture.Id)">
                                                <i class="fas fa-edit"></i>
                                                编辑
                                            </button>
                                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteAsync(picture.Id)">
                                                <i class="fas fa-trash"></i>
                                                删除
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <Pagination CurrentPage="_pageIndex"
                            TotalPages="_totalPages"
                            TotalCount="_totalCount"
                            PageSize="PageSize"
                            OnPageChanged="HandlePageChanged" />
            </div>
        }

        @if (_viewMode == "grid")
        {
            <Pagination CurrentPage="_pageIndex"
                        TotalPages="_totalPages"
                        TotalCount="_totalCount"
                        PageSize="PageSize"
                        OnPageChanged="HandlePageChanged" />
        }
    }
</div>