@page "/comment"
@page "/comment/{NodeParam?}"
@using Dpz.Core.EnumLibrary
@attribute [Authorize]

<div class="comment-list">
    <div class="comment-list__header">
        <h1 class="page-title">
            <i class="fas fa-comments"></i>
            评论管理
        </h1>
        <p class="page-description">集中管理用户评论与回复内容</p>
    </div>

    <div class="comment-list__toolbar">
        <div class="comment-list__toolbar-left">
            <select class="form-control form-select" @bind="_nodeValue" @bind:after="HandleNodeChanged">
                <option value="">全部类型</option>
                <option value="@CommentNode.Article">文章</option>
                <option value="@CommentNode.Code">源码</option>
                <option value="@CommentNode.Friends">友链</option>
                <option value="@CommentNode.Mumble">碎碎念</option>
                <option value="@CommentNode.Other">其它</option>
            </select>

            <select class="form-control form-select" @bind="_relation" @bind:after="HandleRelationChanged">
                <option value="">全部关联</option>
                @foreach (var item in _relationItems.OrderBy(x => x.Id))
                {
                    <option value="@item.Id">@item.Title</option>
                }
            </select>
        </div>

        <div class="comment-list__toolbar-right">
            <button class="btn btn-primary" @onclick="Search" disabled="@_isLoading">
                <i class="fas fa-search"></i>
                查询
            </button>
            <button class="btn-icon" title="刷新" @onclick="Reload" disabled="@_isLoading">
                <i class="fas fa-sync-alt @(_isLoading ? "fa-spin" : "")"></i>
            </button>
            <div class="comment-list__summary">
                <span class="comment-list__summary-label">共</span>
                <span class="comment-list__summary-value">@_totalCount</span>
                <span class="comment-list__summary-label">条</span>
            </div>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="comment-list-skeleton">
            <div class="comment-list-skeleton__table">
                @for (var i = 0; i < 6; i++)
                {
                    <div class="comment-list-skeleton__row">
                        <div class="skeleton skeleton--avatar"></div>
                        <div class="skeleton skeleton--text-lg"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--button"></div>
                    </div>
                }
            </div>
        </div>
    }
    else if (_comments.Count == 0)
    {
        <div class="comment-list__empty">
            <i class="fas fa-comment-slash fa-3x" style="margin-bottom: var(--spacing-md); opacity: 0.3;"></i>
            <p>暂无评论数据</p>
        </div>
    }
    else
    {
        <div class="comment-table">
            <div class="comment-table__wrapper">
                <table>
                    <thead>
                    <tr>
                        <th>用户</th>
                        <th>关联</th>
                        <th>内容</th>
                        <th>时间</th>
                        <th>操作</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in _comments)
                    {
                        <tr>
                            <td data-label="用户">
                                <div class="comment-table__user">
                                    <img src="@GetAvatarUrl(item)" alt="@item.NickName" class="comment-table__avatar" loading="lazy" />
                                    <div class="comment-table__user-info">
                                        <div class="comment-table__user-name">@item.NickName</div>
                                        <div class="comment-table__user-meta">
                                            <span class="comment-table__badge @(item.IsGuest ? "comment-table__badge--guest" : "comment-table__badge--member")">
                                                @(item.IsGuest ? "匿名" : "成员")
                                            </span>
                                            @if (!string.IsNullOrWhiteSpace(item.Identity))
                                            {
                                                <span class="comment-table__identity">@item.Identity</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(item.Site))
                                        {
                                            <div class="comment-table__user-links">
                                                <a href="@item.Site" target="_blank" rel="noreferrer">个人网站</a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td data-label="关联">
                                <div class="comment-table__relation">
                                    <span class="comment-table__node">@GetNodeText(item.Node)</span>
                                    <span class="comment-table__relation-title">
                                        @if (item.Node == CommentNode.Article)
                                        {
                                            <a target="_blank" href="@ArticleReadLink(item)">@GetRelationTitle(item.Relation)</a>
                                        }
                                        else
                                        {
                                            @GetRelationTitle(item.Relation)
                                        }
                                    </span>
                                </div>
                            </td>
                            <td data-label="内容">
                                <div class="comment-table__content @(IsLongComment(item.CommentText) ? "comment-table__content--preview" : "")"
                                     title="@item.CommentText">
                                    @GetCommentPreview(item.CommentText)
                                </div>
                            </td>
                            <td data-label="时间">
                                <div class="comment-table__time">
                                    @item.PublishTime.ToString("yyyy-MM-dd HH:mm:ss")
                                </div>
                            </td>
                            <td data-label="操作">
                                <div class="comment-table__actions">
                                    @if (IsLongComment(item.CommentText))
                                    {
                                        <button class="btn btn-secondary btn-sm" @onclick="() => ViewContent(item)">
                                            <i class="fas fa-eye"></i>
                                            查看
                                        </button>
                                    }
                                    @if (item.IsDelete)
                                    {
                                        <span class="comment-table__deleted">已删除</span>
                                    }
                                    else
                                    {
                                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteAsync(item.Id)">
                                            <i class="fas fa-trash"></i>
                                            删除
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <Pagination CurrentPage="_pageIndex"
                    TotalPages="_totalPages"
                    TotalCount="_totalCount"
                    PageSize="PageSize"
                    OnPageChanged="HandlePageChanged" />
    }
</div>
