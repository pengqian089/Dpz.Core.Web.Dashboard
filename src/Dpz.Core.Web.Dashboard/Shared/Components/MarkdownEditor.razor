@if (!string.IsNullOrEmpty(_editorId))
{
    <div id="markdown-container-@(_editorId)" style="@HeightStyle">
        <div id="@_editorId"></div>
    </div>
    
    @if (_isUploading)
    {
        <div class="editor-loading-overlay">
            <div class="editor-loading-spinner"></div>
            <div class="editor-loading-text">正在上传图片...</div>
        </div>
        
        <style>
            .editor-loading-overlay {
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.7);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                z-index: 1000;
                border-radius: 4px;
            }
            
            .editor-loading-spinner {
                width: 40px;
                height: 40px;
                border: 3px solid rgba(255, 255, 255, 0.3);
                border-radius: 50%;
                border-top-color: #fff;
                animation: spin 1s ease-in-out infinite;
                margin-bottom: 15px;
            }
            
            .editor-loading-text {
                color: #fff;
                font-size: 14px;
                font-weight: 500;
            }
            
            @@keyframes spin {
                to { transform: rotate(360deg); }
            }
            
            #markdown-container-@(_editorId) {
                position: relative;
            }
        </style>
    }
}