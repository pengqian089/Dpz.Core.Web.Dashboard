<div class="account-form" @onkeydown="HandleKeyDown">
    <div class="account-form__header">
        <div>
            <div class="account-form__title">@(IsCreate ? "创建账号" : "修改密码")</div>
            <div class="account-form__subtitle">完善账号信息与安全设置</div>
        </div>
        <i class="fas fa-user-shield account-form__icon"></i>
    </div>

    <div class="account-form__body">
        <div class="form-group">
            <label class="form-label form-label--required">账号</label>
            <input type="text"
                   class="form-control"
                   placeholder="请输入账号"
                   @bind="_accountValue"
                   @bind:event="oninput"
                   readonly="@(!IsCreate)"/>
        </div>

        <div class="form-group">
            <label class="form-label form-label--required">昵称</label>
            <input type="text"
                   class="form-control"
                   placeholder="请输入昵称"
                   @bind="_nameValue"
                   @bind:event="oninput"
                   readonly="@(!IsCreate)"/>
        </div>

        <div class="form-group">
            <label class="form-label form-label--required">密码</label>
            <div class="input-with-icon">
                <input type="@PasswordInputType"
                       class="form-control"
                       placeholder="请输入密码"
                       @bind="_password"
                       @bind:event="oninput"/>
                <button type="button" class="input-icon-btn" @onclick="TogglePasswordVisibility">
                    <i class="fas @PasswordToggleIcon"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="account-form__footer">
        <button class="btn btn-secondary" @onclick="Cancel" disabled="@_isSubmitting">取消</button>
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_isSubmitting">
            @if (_isSubmitting)
            {
                <span class="btn-loading">
                    <span class="btn-loading__spinner"></span>
                    提交中
                </span>
            }
            else
            {
                <span>@(IsCreate ? "创建账号" : "修改密码")</span>
            }
        </button>
    </div>
</div>