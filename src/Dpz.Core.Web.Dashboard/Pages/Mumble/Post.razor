@page "/mumble/post"
@attribute [Authorize]

<div class="mumble-form">
    <div class="mumble-form__header">
        <h1 class="mumble-form__title">发布碎碎念</h1>
        <p class="mumble-form__description">分享你的想法和感受</p>
    </div>

    @if (_isPublishing)
    {
        <div class="publishing-overlay">
            <div style="text-align: center;">
                <div class="publishing-overlay__spinner"></div>
                <div class="publishing-overlay__text">正在发布...</div>
            </div>
        </div>
    }

    <EditForm Model="@_model" OnValidSubmit="PostDataAsync">
        <DataAnnotationsValidator/>

        <div class="mumble-form__content">
            <div class="form-section">
                <div class="form-section__header">
                    <h3 class="form-section__title">
                        <i class="fas fa-comment"></i> 内容编辑
                    </h3>
                </div>
                <div class="form-section__body">
                    <div class="form-group">
                        <label class="form-label form-label--required">碎碎念内容</label>
                        <MarkdownEditor
                            @ref="_editor"
                            Height="600"
                            Markdown=""
                            UploadAction="/api/Mumble/upload">
                        </MarkdownEditor>
                        <ValidationMessage For="@(() => _model)" />
                        <div class="form-helper">
                            <i class="fas fa-info-circle"></i>
                            支持 Markdown 语法，可上传图片和链接
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mumble-form__actions">
            <button type="submit" class="btn btn-primary btn-lg" disabled="@_isPublishing">
                @if (_isPublishing)
                {
                    <span class="btn-loading">
                        <span class="btn-loading__spinner"></span>
                        发布中...
                    </span>
                }
                else
                {
                    <i class="fas fa-paper-plane"></i>
                    <span>发布碎碎念</span>
                }
            </button>
            <a href="/mumble" class="btn btn-secondary btn-lg">
                <i class="fas fa-times"></i>
                <span>取消</span>
            </a>
        </div>
    </EditForm>
</div>