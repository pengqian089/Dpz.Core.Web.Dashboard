@page "/no-permission"
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@layout PublicLayout
@inject NavigationManager Navigation

<div class="auth-state">
    <div class="auth-state__icon auth-state__icon--warning">
        <i class="fas fa-exclamation-triangle"></i>
    </div>
    <h1 class="auth-state__title">权限不足</h1>
    <div class="auth-alert auth-alert--warning">
        <i class="fas fa-shield-alt auth-alert__icon"></i>
        <div class="auth-alert__content">
            当前账号的权限不足以访问此页面。
        </div>
    </div>
    <div class="auth-actions">
        <button class="btn-auth btn-auth--primary" @onclick="LogOut">
            <i class="fas fa-sign-out-alt"></i>
            退出登录
        </button>
    </div>
</div>

@code {
    private void LogOut(MouseEventArgs obj)
    {
        Navigation.NavigateToLogout("authentication/logout");
    }
}