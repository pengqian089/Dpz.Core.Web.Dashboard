@page "/picture/post"
@attribute [Authorize]

<div class="picture-form">
    <div class="picture-form__header">
        <h1 class="picture-form__title">上传图片</h1>
        <p class="picture-form__description">选择并上传新的图片资源到系统</p>
    </div>

    <EditForm Model="_picture" OnValidSubmit="PostPictureAsync">
        <DataAnnotationsValidator />

        <div class="picture-form__content">
            <div class="picture-form__main">
                <div class="upload-section">
                    <div class="upload-section__header">
                        <i class="fas fa-cloud-upload-alt"></i>
                        <span>选择图片文件</span>
                    </div>
                    <div class="upload-section__body">
                        <InputFile OnChange="OnInputFileChanged" id="fileInput" hidden accept="@(string.Join(',', AppTools.ImageExtensions.Select(x => '.' + x)))" />

                        <label for="fileInput" class="upload-area">
                            <div class="upload-area__icon">
                                <i class="fas fa-image"></i>
                            </div>
                            <div class="upload-area__title">点击选择要上传的图片</div>
                            <div class="upload-area__hint">支持 @string.Join(", ", AppTools.ImageExtensions.Take(5)) 等格式</div>
                            <div class="upload-area__button" role="button">
                                <i class="fas fa-folder-open"></i>
                                <span>浏览文件</span>
                            </div>
                        </label>

                        @if (_selectedFiles.Any())
                        {
                            <div class="file-list">
                                @foreach (var file in _selectedFiles)
                                {
                                    <div class="file-list__item">
                                        <div class="file-list__icon">
                                            <i class="fas fa-file-image"></i>
                                        </div>
                                        <div class="file-list__info">
                                            <div class="file-list__name">@file.Key</div>
                                            <div class="file-list__size">@file.Value.FileSize()</div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="preview-image">
                                <img id="imagePreview" alt="预览" />
                            </div>
                        }
                    </div>
                </div>

                <div class="form-section">
                    <div class="form-section__header">
                        <i class="fas fa-tags"></i>
                        <span>标签选择</span>
                    </div>
                    <div class="form-section__body">
                        <div class="tag-selector-wrapper">
                            <div class="tag-selector__label">
                                <i class="fas fa-tag"></i>
                                <span>选择标签（可多选）</span>
                            </div>
                            <div class="tag-selector">
                                @foreach (var tag in _tags)
                                {
                                    <button type="button" 
                                            class="tag-selector__item @(_picture.Tags?.Contains(tag) == true ? "tag-selector__item--active" : "")"
                                            @onclick="() => ToggleTag(tag)">
                                        <i class="fas @(_picture.Tags?.Contains(tag) == true ? "fa-check-circle" : "fa-circle")"></i>
                                        <span>@tag</span>
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-plus-circle"></i>
                                <span>补充标签</span>
                            </label>
                            <input type="text"
                                   class="form-input"
                                   placeholder="多个标签以英文逗号(,)隔开"
                                   @bind="_picture.AdditionsTags" />
                            <div class="form-helper">
                                <i class="fas fa-info-circle"></i>
                                <span>上面标签不满足时，在此输入补充标签</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <div class="form-section__header">
                        <i class="fas fa-align-left"></i>
                        <span>图片描述</span>
                    </div>
                    <div class="form-section__body">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-file-alt"></i>
                                <span>描述内容</span>
                            </label>
                            <textarea class="form-input form-textarea"
                                      rows="5"
                                      placeholder="请输入图片描述信息..."
                                      @bind="_picture.Description"></textarea>
                            <div class="form-helper">
                                <i class="fas fa-info-circle"></i>
                                <span>简要描述图片内容，便于后续查找和管理</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="picture-form__actions">
            <button type="submit" class="btn btn-success btn-lg" disabled="@_isPosting">
                @if (_isPosting)
                {
                    <i class="fas fa-spinner fa-spin"></i>
                    <span>正在上传</span>
                }
                else
                {
                    <i class="fas fa-cloud-upload-alt"></i>
                    <span>上传图片</span>
                }
            </button>
            <a href="/picture" class="btn btn-secondary btn-lg">
                <i class="fas fa-arrow-left"></i>
                <span>返回列表</span>
            </a>
        </div>
    </EditForm>

    @if (_isPosting)
    {
        <div class="picture-form__loading-overlay">
            <div class="picture-form__loading-content">
                <div class="picture-form__loading-spinner"></div>
                <div class="picture-form__loading-text">正在上传图片，请稍候...</div>
                <div class="picture-form__progress">
                    <div class="picture-form__progress-bar" style="width: @(_uploadProgress)%"></div>
                </div>
                <div class="picture-form__progress-text">@_uploadProgress%</div>
            </div>
        </div>
    }
</div>