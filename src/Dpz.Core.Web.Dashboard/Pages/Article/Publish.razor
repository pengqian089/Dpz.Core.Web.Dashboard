@page "/article/publish"
@attribute [Authorize]

<div class="article-form">
    <div class="article-form__header">
        <h1 class="article-form__title">发布文章</h1>
        <p class="article-form__description">创建新的博客文章</p>
    </div>

    @if (_isPublishing)
    {
        <div class="publishing-overlay">
            <div style="text-align: center;">
                <div class="publishing-overlay__spinner"></div>
                <div class="publishing-overlay__text">正在发布文章...</div>
            </div>
        </div>
    }

    <EditForm Model="@_article" OnValidSubmit="PublishArticleAsync">
        <DataAnnotationsValidator/>

        <div class="article-form__content">
            <div class="article-form__main">
                <div class="form-section">
                    <div class="form-section__header">
                        <i class="fas fa-align-left"></i>
                        <span>基本信息</span>
                    </div>
                    <div class="form-section__body">
                        <div class="form-group">
                            <label class="form-label form-label--required" for="title">文章标题</label>
                            <input type="text"
                                   id="title"
                                   class="form-input"
                                   placeholder="请输入一个吸引人的标题"
                                   @bind="_article.Title"
                                   @bind:event="oninput"/>
                            <ValidationMessage For="@(() => _article.Title)" />
                        </div>

                        <div class="form-group">
                            <label class="form-label form-label--required">文章标签</label>
                            <div class="tag-selector">
                                @foreach (var tag in _tags)
                                {
                                    <button type="button"
                                            class="tag-selector__item @(_article.Tags.Contains(tag) ? "tag-selector__item--active" : "")"
                                            @onclick="() => ToggleTag(tag)">
                                        <i class="fas @(_article.Tags.Contains(tag) ? "fa-check-circle" : "fa-circle")"></i>
                                        @tag
                                    </button>
                                }
                            </div>
                            <ValidationMessage For="@(() => _article.Tags)" />
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="addTag">
                                <i class="fas fa-plus-circle"></i>
                                添加新标签
                            </label>
                            <div class="input-with-icon">
                                <input type="text"
                                       id="addTag"
                                       class="form-input"
                                       placeholder="输入新标签并回车添加"
                                       @bind="_addTag"
                                       @bind:event="oninput"
                                       @onkeydown="HandleAddTagKeyDown"/>
                                @if (!string.IsNullOrEmpty(_addTag))
                                {
                                    <button type="button" class="input-icon-btn" @onclick="AddNewTag">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <div class="form-section__header">
                        <i class="fas fa-file-alt"></i>
                        <span>文章简介</span>
                    </div>
                    <div class="form-section__body">
                        <div class="form-group">
                            <label class="form-label form-label--required" for="introduction">简介内容</label>
                            <textarea id="introduction"
                                      class="form-input form-textarea"
                                      placeholder="用一段精彩的简介吸引读者..."
                                      rows="4"
                                      @bind="_article.Introduction"
                                      @bind:event="oninput"></textarea>
                            <ValidationMessage For="@(() => _article.Introduction)" />
                            <div class="form-helper">
                                <i class="fas fa-info-circle"></i>
                                建议 100-200 字，简明扼要地介绍文章核心内容
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section form-section--editor">
                    <div class="form-section__header">
                        <i class="fas fa-keyboard"></i>
                        <span>文章正文</span>
                    </div>
                    <div class="form-section__body">
                        <MarkdownEditor
                            Markdown="@_article.Markdown"
                            @ref="_editor"
                            UploadAction="/api/Article/upload">
                        </MarkdownEditor>
                    </div>
                </div>
            </div>
        </div>

        <div class="article-form__actions">
            <button type="submit" class="btn btn-primary btn-lg" disabled="@_isPublishing">
                @if (_isPublishing)
                {
                    <span class="btn-loading">
                        <span class="btn-loading__spinner"></span>
                        <span>正在发布</span>
                    </span>
                }
                else
                {
                    <span>
                        <i class="fas fa-paper-plane"></i>
                        发布文章
                    </span>
                }
            </button>
            <a href="/article" class="btn btn-secondary btn-lg">
                <i class="fas fa-times"></i>
                返回列表
            </a>
        </div>
    </EditForm>
</div>