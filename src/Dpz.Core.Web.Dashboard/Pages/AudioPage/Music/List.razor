@page "/music"
@page "/music/list"
@attribute [Authorize]
@using Dpz.Core.Web.Dashboard.Shared.Components

<div class="music-list">
    <div class="music-list__header">
        <h1 class="page-title">音乐管理</h1>
        <p class="page-description">管理和维护网站的所有音乐内容</p>
    </div>

    <div class="music-list__toolbar">
        <div class="music-list__toolbar-left">
            <button class="btn btn-primary" @onclick="AddMusic">
                <i class="fas fa-plus"></i>
                发布音乐
            </button>
        </div>

        <div class="music-list__toolbar-right">
            <input type="text"
                   class="form-control"
                   placeholder="搜索音乐标题..."
                   @bind="_title"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown" />

            <button class="btn btn-primary" @onclick="Search">
                <i class="fas fa-search"></i>
                搜索
            </button>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="music-list-skeleton">
            <div class="music-list-skeleton__table">
                @for (var i = 0; i < 5; i++)
                {
                    <div class="music-list-skeleton__row">
                        <div class="skeleton skeleton--text-lg"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--button"></div>
                    </div>
                }
            </div>
        </div>
    }
    else if (Items is null || !Items.Any())
    {
        <div class="music-list__empty">
            <i class="fas fa-music fa-3x" style="margin-bottom: var(--spacing-md); opacity: 0.3;"></i>
            <p>暂无音乐数据</p>
        </div>
    }
    else
    {
        <div class="music-table">
            <div class="music-table__wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>歌曲名</th>
                            <th>歌手</th>
                            <th>文件名</th>
                            <th>分组</th>
                            <th>时长</th>
                            <th>来源</th>
                            <th>歌词</th>
                            <th>文件大小</th>
                            <th>上传时间</th>
                            <th>最后修改时间</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var music in Items)
                        {
                            <tr>
                                <td data-label="歌曲名">
                                    <div class="music-table__title">
                                        <span title="@music.Title">@music.Title</span>
                                    </div>
                                </td>
                                <td data-label="歌手">@music.Artist</td>
                                <td data-label="文件名">
                                    <div class="music-table__filename" title="@music.FileName">
                                        @music.FileName
                                    </div>
                                </td>
                                <td data-label="分组">
                                    <div class="music-table__tags">
                                        @if (music.Group != null)
                                        {
                                            foreach (var g in music.Group)
                                            {
                                                <span class="music-table__tag">@g</span>
                                            }
                                        }
                                    </div>
                                </td>
                                <td data-label="时长">
                                    @{
                                        var duration = TimeSpan.TryParse(music.Duration, out var d) ? d : TimeSpan.Zero;
                                    }
                                    @string.Format("{0:00}:{1:00}:{2:00}", duration.Hours, duration.Minutes, duration.Seconds)
                                </td>
                                <td data-label="来源">@music.From</td>
                                <td data-label="歌词">
                                    @if (string.IsNullOrEmpty(music.LyricUrl))
                                    {
                                        <span class="music-table__no-lyric">无</span>
                                    }
                                    else
                                    {
                                        <span class="music-table__has-lyric">有</span>
                                    }
                                </td>
                                <td data-label="文件大小">@music.MusicLength.FileSize()</td>
                                <td data-label="上传时间">@music.UploadTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td data-label="最后修改时间">@music.LastUpdateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td data-label="操作">
                                    <div class="music-table__actions">
                                        <button class="btn btn-primary btn-sm" @onclick="() => ViewDetail(music.Id)">
                                            <i class="fas fa-eye"></i>
                                            详情
                                        </button>
                                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteAsync(music.Id)">
                                            <i class="fas fa-trash"></i>
                                            删除
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <Pagination CurrentPage="_pageIndex"
                        TotalPages="_totalPages"
                        TotalCount="_totalCount"
                        PageSize="PageSize"
                        OnPageChanged="HandlePageChanged" />
        </div>
    }
</div>
