@page "/mumble"
@page "/mumble/list"
@attribute [Authorize]

<div class="mumble-list">
    <div class="mumble-list__header">
        <h1 class="page-title">碎碎念管理</h1>
        <p class="page-description">管理和发布碎碎念动态</p>
    </div>

    <div class="mumble-list__toolbar">
        <div class="mumble-list__toolbar-left">
            <a href="/mumble/post" class="btn btn-primary">
                <i class="fas fa-plus"></i>
                发布碎碎念
            </a>
        </div>

        <div class="mumble-list__toolbar-right">
            <input type="text"
                   class="form-control"
                   placeholder="搜索内容..."
                   @bind="_content"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown" />

            <button class="btn btn-primary" @onclick="OnSearch">
                <i class="fas fa-search"></i>
                搜索
            </button>
        </div>
    </div>

@if (!_isLoading)
{
    @if (_data.Count > 0)
    {
        <div class="mumble-list__cards">
            @foreach (var item in _data)
            {
                <div class="mumble-card">
                    <div class="mumble-card__header">
                        <div class="mumble-card__author">
                            @if (string.IsNullOrEmpty(item.Author.Avatar))
                            {
                                <div class="mumble-card__avatar flex items-center justify-center" style="background-color: var(--primary);">
                                    <span class="text-white text-xs">@item.Author.Name.FirstOrDefault()</span>
                                </div>
                            }
                            else
                            {
                                <img src="@item.Author.Avatar" class="mumble-card__avatar" alt="@item.Author.Name" />
                            }
                            <span>@item.Author.Name</span>
                        </div>
                        
                        <div class="mumble-card__meta">
                            <span title="发布时间">
                                <i class="far fa-clock"></i> @item.CreateTime.ToString("yyyy-MM-dd HH:mm")
                            </span>
                        </div>
                    </div>

                    <div class="mumble-card__content">
                        @item.Markdown
                    </div>

                    <div class="mumble-card__footer">
                        <div class="mumble-card__stats">
                            <span title="点赞数">
                                <i class="fas fa-heart text-danger"></i> @item.Zan
                            </span>
                            <span title="评论数">
                                <i class="fas fa-comment text-info"></i> @item.CommentCount
                            </span>
                             <span title="最后更新">
                                 <i class="fas fa-history"></i> @item.LastUpdateTime.ToString("yyyy-MM-dd HH:mm:ss")
                            </span>
                        </div>

                        <div class="mumble-card__actions">
                            <button class="btn btn-sm btn-secondary" @onclick="() => Preview(item)">
                                <i class="fas fa-eye"></i> 预览
                            </button>
                            <a href="/mumble/edit/@item.Id" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> 编辑
                            </a>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteAsync(item.Id)">
                                <i class="fas fa-trash"></i> 删除
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <Pagination CurrentPage="_pageIndex"
                    TotalPages="_totalPages"
                    TotalCount="_totalCount"
                    PageSize="PageSize"
                    OnPageChanged="HandlePageChanged" />
    }
    else
    {
        <div class="mumble-list__empty">
            <i class="fas fa-comments fa-3x" style="margin-bottom: var(--spacing-md); opacity: 0.3;"></i>
            <p>暂无碎碎念数据</p>
        </div>
    }
}
else
{
    <div class="mumble-list-skeleton">
        <div class="mumble-list-skeleton__grid">
            @for (var i = 0; i < 6; i++)
            {
                <div class="mumble-list-skeleton__card">
                    <div class="skeleton skeleton--text-lg" style="margin-bottom: var(--spacing-md);"></div>
                    <div class="skeleton skeleton--text" style="margin-bottom: var(--spacing-sm);"></div>
                    <div class="skeleton skeleton--text" style="width: 80%; margin-bottom: var(--spacing-md);"></div>
                    <div style="display: flex; gap: var(--spacing-sm);">
                        <div class="skeleton skeleton--button"></div>
                        <div class="skeleton skeleton--button"></div>
                        <div class="skeleton skeleton--button"></div>
                    </div>
                </div>
            }
        </div>
    </div>
}
</div>
