@page "/mumble/edit/{Id}"
@attribute [Authorize]

<div class="mumble-form">
    <div class="mumble-form__header">
        <h1 class="mumble-form__title">编辑碎碎念</h1>
        <p class="mumble-form__description">修改你的想法和感受</p>
    </div>

    @if (_isLoading)
    {
        <div class="form-section">
            <div class="form-section__body">
                <div class="skeleton skeleton--text-lg" style="margin-bottom: var(--spacing-md);"></div>
                <div class="skeleton" style="height: 600px; margin-bottom: var(--spacing-md);"></div>
                <div style="display: flex; gap: var(--spacing-sm);">
                    <div class="skeleton skeleton--button"></div>
                    <div class="skeleton skeleton--button"></div>
                </div>
            </div>
        </div>
    }
    else if (_model != null)
    {
        @if (_isPublishing)
        {
            <div class="publishing-overlay">
                <div style="text-align: center;">
                    <div class="publishing-overlay__spinner"></div>
                    <div class="publishing-overlay__text">正在保存...</div>
                </div>
            </div>
        }

        <EditForm Model="@_editModel" OnValidSubmit="PostDataAsync">
            <DataAnnotationsValidator/>

            <div class="mumble-form__content">
                <div class="form-section">
                    <div class="form-section__header">
                        <h3 class="form-section__title">
                            <i class="fas fa-comment"></i> 内容编辑
                        </h3>
                    </div>
                    <div class="form-section__body">
                        <div class="form-group">
                            <label class="form-label form-label--required">碎碎念内容</label>
                            <MarkdownEditor
                                @ref="_editor"
                                Height="600"
                                Markdown="@_model.Markdown"
                                UploadAction="/api/Mumble/upload">
                            </MarkdownEditor>
                            <ValidationMessage For="@(() => _editModel)" />
                            <div class="form-helper">
                                <i class="fas fa-info-circle"></i>
                                支持 Markdown 语法，可上传图片和链接
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mumble-form__actions">
                <button type="submit" class="btn btn-primary btn-lg" disabled="@_isPublishing">
                    @if (_isPublishing)
                    {
                        <span class="btn-loading">
                            <span class="btn-loading__spinner"></span>
                            保存中...
                        </span>
                    }
                    else
                    {
                        <i class="fas fa-save"></i>
                        <span>保存修改</span>
                    }
                </button>
                <a href="/mumble" class="btn btn-secondary btn-lg">
                    <i class="fas fa-times"></i>
                    <span>取消</span>
                </a>
            </div>
        </EditForm>
    }
    else
    {
        <div class="form-section">
            <div class="form-section__body" style="text-align: center; padding: var(--spacing-xxxl);">
                <i class="fas fa-exclamation-triangle" style="font-size: 3rem; color: var(--danger); margin-bottom: var(--spacing-md);"></i>
                <p style="color: var(--text-secondary);">数据加载失败</p>
            </div>
        </div>
    }
</div>