@page "/audio"
@page "/audio/list"
@attribute [Authorize]
@using Dpz.Core.Web.Dashboard.Shared.Components

<div class="audio-list">
    <div class="audio-list__header">
        <div>
            <h1 class="audio-list__title">录音管理</h1>
            <p class="audio-list__description">管理和预览已上传的录音文件</p>
        </div>
        <button class="btn btn-secondary" @onclick="RefreshAsync" disabled="@_isLoading">
            <i class="fas fa-sync-alt @(_isLoading ? "fa-spin" : "")"></i>
            刷新
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="audio-list__table-container">
            <div style="padding: 20px;">
                <div class="skeleton" style="height: 40px; margin-bottom: 10px;"></div>
                <div class="skeleton" style="height: 60px; margin-bottom: 10px;"></div>
                <div class="skeleton" style="height: 60px; margin-bottom: 10px;"></div>
                <div class="skeleton" style="height: 60px; margin-bottom: 10px;"></div>
                <div class="skeleton" style="height: 60px;"></div>
            </div>
        </div>
    }
    else
    {
        <div class="audio-list__table-container">
            <table class="audio-table">
                <thead>
                    <tr>
                        <th style="width: 350px;">录音预览</th>
                        <th>文件大小</th>
                        <th>上传人</th>
                        <th>上传时间</th>
                        <th style="width: 100px;">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_audios.Count > 0)
                    {
                        @foreach (var item in _audios)
                        {
                            <tr>
                                <td>
                                    <AudioPlayer Src="@item.AccessUrl" />
                                </td>
                                <td>@item.Size.FileSize()</td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <i class="fas fa-user-circle" style="color: var(--text-secondary);"></i>
                                        @item.Uploader?.Name
                                    </div>
                                </td>
                                <td>@item.UploadTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>
                                    <button class="btn btn-icon btn-danger" @onclick="() => DeleteAsync(item.Id)" title="删除">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="audio-table__empty">
                                    <i class="fas fa-music fa-3x" style="margin-bottom: 1rem; opacity: 0.3;"></i>
                                    <p>暂无录音数据</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <Pagination CurrentPage="_pageIndex"
                    TotalPages="_audios.TotalPageCount"
                    TotalCount="_audios.TotalItemCount"
                    PageSize="PageSize"
                    OnPageChanged="HandlePageChanged" />
    }
</div>