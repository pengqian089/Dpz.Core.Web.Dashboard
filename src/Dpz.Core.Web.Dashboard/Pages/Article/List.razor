@page "/article"
@page "/article/list"
@attribute [Authorize]
@using Dpz.Core.Web.Dashboard.Shared.Components

<div class="article-list">
    <div class="article-list__header">
        <h1 class="page-title">文章管理</h1>
        <p class="page-description">管理和维护网站的所有文章内容</p>
    </div>

    <div class="article-list__toolbar">
        <div class="article-list__toolbar-left">
            <button class="btn btn-primary" @onclick="PublishArticle">
                <i class="fas fa-plus"></i>
                发布文章
            </button>
        </div>

        <div class="article-list__toolbar-right">
            <select class="form-control form-select" @bind="_tag" @bind:after="Search">
                <option value="">全部标签</option>
                @foreach (var item in _tags)
                {
                    <option value="@item">@item</option>
                }
            </select>

            <input type="text"
                   class="form-control"
                   placeholder="搜索标题..."
                   @bind="_title"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown" />

            <button class="btn btn-primary" @onclick="Search">
                <i class="fas fa-search"></i>
                搜索
            </button>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="article-list-skeleton">
            <div class="article-list-skeleton__table">
                @for (var i = 0; i < 5; i++)
                {
                    <div class="article-list-skeleton__row">
                        <div class="skeleton skeleton--text-lg"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--button"></div>
                    </div>
                    <div class="article-list-skeleton__mobile-card">
                        <div class="article-list-skeleton__mobile-header">
                            <div class="skeleton skeleton--text-lg" style="width: 70%;"></div>
                            <div class="skeleton skeleton--button" style="width: 60px;"></div>
                        </div>
                        <div class="article-list-skeleton__mobile-body">
                            <div class="skeleton skeleton--text" style="width: 40%;"></div>
                            <div class="skeleton skeleton--text" style="width: 60%;"></div>
                            <div class="skeleton skeleton--text" style="width: 50%;"></div>
                        </div>
                        <div class="article-list-skeleton__mobile-footer">
                            <div class="skeleton skeleton--button" style="width: 48%; height: 36px;"></div>
                            <div class="skeleton skeleton--button" style="width: 48%; height: 36px;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (_articles == null || !_articles.Any())
    {
        <div class="article-list__empty">
            <i class="fas fa-inbox fa-3x" style="margin-bottom: var(--spacing-md); opacity: 0.3;"></i>
            <p>暂无文章数据</p>
        </div>
    }
    else
    {
        <div class="article-table">
            <div class="article-table__wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>标题</th>
                            <th>作者</th>
                            <th>回复量</th>
                            <th>查看量</th>
                            <th>标签</th>
                            <th>来源</th>
                            <th>图片</th>
                            <th>发布时间</th>
                            <th>修改时间</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var article in _articles)
                        {
                            <tr>
                                <td data-label="标题">
                                    <div class="article-table__title">
                                        <a href="@($"{Program.WebHost}/article/read/{article.Id}.html")" 
                                           target="_blank"
                                           title="@article.Title">
                                            @HighlightText(article.Title, _title)
                                        </a>
                                    </div>
                                </td>
                                <td data-label="作者">@article.Author.Name</td>
                                <td data-label="回复量">
                                    @if (article.CommentCount > 0)
                                    {
                                        <a href="@($"/comment?node=Article&relation={article.Id}")" 
                                           class="article-table__comment-link">
                                            查看评论 (@article.CommentCount)
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="article-table__no-comment">暂无评论</span>
                                    }
                                </td>
                                <td data-label="查看量">@article.ViewCount.ToString("N0")</td>
                                <td data-label="标签">
                                    <div class="article-table__tags">
                                        @foreach (var tag in article.Tags)
                                        {
                                            <span class="article-table__tag">@tag</span>
                                        }
                                    </div>
                                </td>
                                <td data-label="来源">@article.From</td>
                                <td data-label="图片">@article.ImagesAddress.Count</td>
                                <td data-label="发布时间">@article.CreateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td data-label="修改时间">@article.LastUpdateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td data-label="操作">
                                    <div class="article-table__actions">
                                        <button class="btn btn-primary btn-sm" @onclick="() => EditArticle(article.Id)">
                                            <i class="fas fa-edit"></i>
                                            编辑
                                        </button>
                                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteAsync(article.Id)">
                                            <i class="fas fa-trash"></i>
                                            删除
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <Pagination CurrentPage="_pageIndex"
                        TotalPages="_totalPages"
                        TotalCount="_totalCount"
                        PageSize="PageSize"
                        OnPageChanged="HandlePageChanged" />
        </div>
    }
</div>