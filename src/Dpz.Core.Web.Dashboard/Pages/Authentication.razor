@page "/authentication/{action}"
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

<RemoteAuthenticatorView Action="@Action">
    @* authentication/login *@
    <LoggingIn>
        <div class="auth-state">
            <div class="auth-state__icon auth-state__icon--primary">
                <i class="fas fa-lock-open"></i>
            </div>
            <div class="auth-state__spinner"></div>
            <h1 class="auth-state__title">正在跳转至身份认证中心</h1>
            <p class="auth-state__description">请稍候，无需手动操作</p>
            <p class="auth-state__url">@Configuration["OIDC:Authority"]</p>
        </div>
    </LoggingIn>

    @* authentication/login-callback *@
    <CompletingLoggingIn>
        <div class="auth-state">
            <div class="auth-state__icon auth-state__icon--primary">
                <i class="fas fa-sign-in-alt"></i>
            </div>
            <div class="auth-state__spinner"></div>
            <h1 class="auth-state__title">正在完成登录并返回应用</h1>
            <p class="auth-state__description">正在处理认证信息，请稍候...</p>
        </div>
    </CompletingLoggingIn>

    @* authentication/login-failed *@
    <LogInFailed>
        <div class="auth-state">
            <div class="auth-state__icon auth-state__icon--error">
                <i class="fas fa-exclamation-circle"></i>
            </div>
            <h1 class="auth-state__title">登录失败</h1>
            <div class="auth-alert auth-alert--error">
                <i class="fas fa-times-circle auth-alert__icon"></i>
                <div class="auth-alert__content">
                    登录失败，请重试或稍后再试。
                </div>
            </div>
            <div class="auth-actions">
                <a href="/authentication/login" class="btn-auth btn-auth--primary">
                    <i class="fas fa-redo"></i>
                    重新登录
                </a>
            </div>
        </div>
    </LogInFailed>

    @* authentication/logout *@
    <LogOut>
        <div class="auth-state">
            <div class="auth-state__icon auth-state__icon--primary">
                <i class="fas fa-sign-out-alt"></i>
            </div>
            <div class="auth-state__spinner"></div>
            <h1 class="auth-state__title">正在退出登录</h1>
            <p class="auth-state__description">正在清除登录信息，请稍候...</p>
        </div>
    </LogOut>

    @* authentication/logout-callback *@
    <CompletingLogOut>
        <div class="auth-state">
            <div class="auth-state__icon auth-state__icon--primary">
                <i class="fas fa-sign-out-alt"></i>
            </div>
            <div class="auth-state__spinner"></div>
            <h1 class="auth-state__title">已退出登录</h1>
            <p class="auth-state__description">正在返回应用首页...</p>
        </div>
    </CompletingLogOut>

    @* authentication/logout-failed *@
    <LogOutFailed>
        <div class="auth-state">
            <div class="auth-state__icon auth-state__icon--error">
                <i class="fas fa-exclamation-circle"></i>
            </div>
            <h1 class="auth-state__title">退出失败</h1>
            <div class="auth-alert auth-alert--error">
                <i class="fas fa-times-circle auth-alert__icon"></i>
                <div class="auth-alert__content">
                    退出失败，请重试。
                </div>
            </div>
            <div class="auth-actions">
                <a href="/" class="btn-auth btn-auth--primary">
                    <i class="fas fa-home"></i>
                    返回首页
                </a>
            </div>
        </div>
    </LogOutFailed>

    @* authentication/logged-out *@
    <LogOutSucceeded>
        <div class="auth-state">
            <div class="auth-state__icon auth-state__icon--success">
                <i class="fas fa-check-circle"></i>
            </div>
            <h1 class="auth-state__title">退出成功</h1>
            <div class="auth-alert auth-alert--success">
                <i class="fas fa-check-circle auth-alert__icon"></i>
                <div class="auth-alert__content">
                    您已成功退出登录。
                </div>
            </div>
            <div class="auth-actions">
                <a href="/" class="btn-auth btn-auth--primary">
                    <i class="fas fa-home"></i>
                    返回首页
                </a>
            </div>
        </div>
    </LogOutSucceeded>

    @* authentication/profile *@
    <UserProfile>
        <div class="auth-state">
            <div class="auth-state__icon auth-state__icon--primary">
                <i class="fas fa-user-cog"></i>
            </div>
            <div class="auth-state__spinner"></div>
            <h1 class="auth-state__title">正在打开个人资料</h1>
            <p class="auth-state__description">正在跳转至用户资料页面...</p>
        </div>
    </UserProfile>

    @* authentication/register *@
    <Registering>
        <div class="auth-state">
            <div class="auth-state__icon auth-state__icon--primary">
                <i class="fas fa-user-plus"></i>
            </div>
            <div class="auth-state__spinner"></div>
            <h1 class="auth-state__title">正在跳转至注册</h1>
            <p class="auth-state__description">正在打开用户注册页面...</p>
        </div>
    </Registering>

</RemoteAuthenticatorView>

@code{
    [Parameter] public string Action { get; set; }
}
