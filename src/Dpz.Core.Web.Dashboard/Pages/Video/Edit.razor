@using Dpz.Core.Web.Dashboard.Shared.Components

<div class="form-section">
    <div class="form-section__body">
        @if (_isLoading)
        {
            <div class="skeleton-form">
                <div class="skeleton-form__field"></div>
                <div class="skeleton-form__field"></div>
                <div class="skeleton-form__field"></div>
            </div>
        }
        else if (_model != null)
        {
            <EditForm Model="@_model" OnValidSubmit="SaveAsync">
                <div class="form-group">
                    <label class="form-label form-label--required">视频标题</label>
                    <input class="form-control" @bind="_model.VideoTitle" required/>
                </div>

                <div class="form-group">
                    <label class="form-label">视频副标题</label>
                    <input class="form-control" @bind="_model.SubTitle"/>
                </div>

                <div class="form-group">
                    <label class="form-label">标签</label>
                    <TagInput @bind-Tags="_tagList" 
                              HelperText="按 Enter 或逗号添加标签，点击标签右侧的 X 可删除"
                              MaxTags="10" />
                </div>

                <div class="form-group">
                    <label class="form-label">描述</label>
                    <textarea class="form-control" @bind="_model.Description" rows="4"></textarea>
                </div>

                <div class="form-group" style="display: flex; gap: var(--spacing-md); justify-content: flex-end;">
                    <button type="button" class="btn btn-secondary" @onclick="Cancel" disabled="@_isSaving">
                        取消
                    </button>
                    <button type="submit" class="btn btn-primary" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <span class="btn-loading">
                                <span class="btn-loading__spinner"></span>
                                保存中...
                            </span>
                        }
                        else
                        {
                            <span>保存</span>
                        }
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>
