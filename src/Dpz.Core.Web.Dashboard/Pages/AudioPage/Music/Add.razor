@page "/music/add"
@attribute [Authorize]

<div class="music-form">
    <div class="music-form__header">
        <h1 class="music-form__title">上传音乐</h1>
        <p class="music-form__description">添加新的音乐到您的媒体库</p>
    </div>

    @if (_isPosting)
    {
        <div class="publishing-overlay">
            <div style="text-align: center;">
                <div class="publishing-overlay__spinner"></div>
                <div class="publishing-overlay__text">正在上传音乐...</div>
            </div>
        </div>
    }

    <EditForm Model="@_t" OnValidSubmit="PostMusicAsync">
        <DataAnnotationsValidator />

        <div class="music-form__content">
            <div class="music-form__main">
                <div class="form-section">
                    <div class="form-section__header">
                        <i class="fas fa-music"></i>
                        <span>音频文件</span>
                    </div>
                    <div class="form-section__body">
                        <div class="form-group">
                            <label class="form-label form-label--required">选择音乐文件</label>
                            <div class="file-upload-zone">
                                <InputFile OnChange="OnMusicChanged" id="musicFile" accept=".mp3,.flac,.ogg"
                                    class="file-upload-zone__input" />
                                <label for="musicFile" class="file-upload-zone__label">
                                    @if (_selectMusic?.Any() == true)
                                    {
                                        <div class="file-upload-zone__selected">
                                            <i class="fas fa-file-audio fa-2x"></i>
                                            @foreach (var file in _selectMusic)
                                            {
                                                <div class="file-info">
                                                    <span class="file-info__name">@file.Key</span>
                                                    <span class="file-info__size">@file.Value.FileSize()</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="file-upload-zone__placeholder">
                                            <i class="fas fa-cloud-upload-alt fa-3x"></i>
                                            <span>点击选择音乐文件</span>
                                            <span class="file-upload-zone__hint">支持 MP3, FLAC, OGG 格式</span>
                                        </div>
                                    }
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <div class="form-section__header">
                        <i class="fas fa-image"></i>
                        <span>封面图片</span>
                    </div>
                    <div class="form-section__body">
                        <div class="form-group">
                            <label class="form-label">选择封面</label>
                            <div class="file-upload-zone file-upload-zone--image">
                                <InputFile OnChange="OnCoverChanged" id="coverFile" accept="image/*"
                                    class="file-upload-zone__input" />
                                <label for="coverFile" class="file-upload-zone__label">
                                    @if (_selectCover.Count > 0)
                                    {
                                        <div class="file-upload-zone__selected">
                                            <i class="fas fa-image fa-2x"></i>
                                            @foreach (var file in _selectCover)
                                            {
                                                <div class="file-info">
                                                    <span class="file-info__name">@file.Key</span>
                                                    <span class="file-info__size">@file.Value.FileSize()</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="file-upload-zone__placeholder">
                                            <i class="fas fa-image fa-2x"></i>
                                            <span>选择封面图片（可选）</span>
                                            <span class="file-upload-zone__hint">推荐 1000x1000 尺寸</span>
                                        </div>
                                    }
                                </label>
                            </div>

                            @if (!string.IsNullOrEmpty(_coverPreviewUrl))
                            {
                                <div class="cover-preview" style="margin-top: var(--spacing-md);">
                                    <img src="@_coverPreviewUrl" alt="封面预览"
                                        style="max-width: 300px; border-radius: var(--border-radius); border: 1px solid var(--border-color);" />
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <div class="form-section__header">
                        <i class="fas fa-align-left"></i>
                        <span>歌词文件</span>
                    </div>
                    <div class="form-section__body">
                        <div class="form-group">
                            <label class="form-label">选择歌词</label>
                            <div class="file-upload-zone">
                                <InputFile OnChange="OnLrcChanged" id="lrcFile" accept=".lrc"
                                    class="file-upload-zone__input" />
                                <label for="lrcFile" class="file-upload-zone__label">
                                    @if (_selectLrc.Count > 0)
                                    {
                                        <div class="file-upload-zone__selected">
                                            <i class="fas fa-file-alt fa-2x"></i>
                                            @foreach (var file in _selectLrc)
                                            {
                                                <div class="file-info">
                                                    <span class="file-info__name">@file.Key</span>
                                                    <span class="file-info__size">@file.Value.FileSize()</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="file-upload-zone__placeholder">
                                            <i class="fas fa-file-alt fa-2x"></i>
                                            <span>选择歌词文件（可选）</span>
                                            <span class="file-upload-zone__hint">仅支持 LRC 格式</span>
                                        </div>
                                    }
                                </label>
                            </div>

                            @if (!string.IsNullOrEmpty(_lrcContent))
                            {
                                <div class="lyric-preview" style="margin-top: var(--spacing-md);">
                                    <pre><code>@_lrcContent</code></pre>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <div class="form-section__header">
                        <i class="fas fa-tags"></i>
                        <span>分组设置</span>
                    </div>
                    <div class="form-section__body">
                        <div class="form-group">
                            <label class="form-label">选择分组</label>
                            <div class="tag-selector">
                                @foreach (var group in _groups)
                                {
                                    <button type="button"
                                            class="tag-selector__item @(_selectedGroups.Contains(group) ? "tag-selector__item--active" : "")"
                                            @onclick="() => ToggleGroup(group)">
                                        <i class="fas @(_selectedGroups.Contains(group) ? "fa-check-circle" : "fa-circle")"></i>
                                        @group
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="addGroup">添加新分组</label>
                            <div style="display: flex; gap: var(--spacing-sm);">
                                <input type="text" id="addGroup" class="form-control" placeholder="输入新分组名称"
                                    @bind="_addGroup" @bind:event="oninput" @onkeydown="HandleAddGroupKeyDown"
                                    @onkeydown:preventDefault="@_preventDefault" />
                                <button type="button" class="btn btn-primary" @onclick="AddNewGroup">
                                    <i class="fas fa-plus"></i>
                                    添加
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="music-form__actions">
            <button type="submit" class="btn btn-primary btn-lg" disabled="@_isPosting">
                @if (_isPosting)
                {
                    <span class="btn-loading">
                        <span class="btn-loading__spinner"></span>
                        <span>正在上传</span>
                    </span>
                }
                else
                {
                    <span>
                        <i class="fas fa-cloud-upload-alt"></i>
                        上传音乐
                    </span>
                }
            </button>
            <a href="/music" class="btn btn-secondary btn-lg">
                <i class="fas fa-times"></i>
                返回列表
            </a>
        </div>
    </EditForm>
</div>