@page "/footer"
@attribute [Authorize]

<div class="footer-form">
    <div class="footer-form__header">
        <h1 class="footer-form__title">页脚管理</h1>
        <p class="footer-form__description">维护前台页脚内容，支持 HTML 编辑</p>
    </div>

    @if (_isLoading)
    {
        <div class="footer-form__skeleton">
            <div class="skeleton skeleton--title skeleton--half"></div>
            <div class="skeleton skeleton--input skeleton--full"></div>
            <div class="skeleton skeleton--editor skeleton--full"></div>
            <div class="footer-form__skeleton-actions">
                <div class="skeleton skeleton--button"></div>
                <div class="skeleton skeleton--button"></div>
            </div>
        </div>
    }
    else
    {
        <EditForm Model="@_formState" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator/>
            <div class="footer-form__content">
                <div class="footer-form__section">
                    <div class="footer-form__section-title">页脚内容</div>
                    <div class="footer-form__editor">
                        <HtmlEditor @ref="_editor" Html="@_content" />
                    </div>
                    <div class="footer-form__hint">
                        建议保持内容简洁，支持 HTML 标签与链接
                    </div>
                </div>
            </div>

            <div class="footer-form__actions">
                <button class="btn btn-secondary" type="button" @onclick="ReloadAsync" disabled="@_isSaving">
                    重新加载
                </button>
                <button class="btn btn-primary" type="submit" disabled="@_isSaving">
                    @if (_isSaving)
                    {
                        <span class="btn-loading">
                            <span class="btn-loading__spinner"></span>
                            保存中
                        </span>
                    }
                    else
                    {
                        <span>保存</span>
                    }
                </button>
            </div>
        </EditForm>
    }
</div>

@if (_isSaving)
{
    <div class="footer-form__loading-overlay">
        <div class="footer-form__loading-content">
            <div class="footer-form__loading-spinner"></div>
            <div class="footer-form__loading-text">正在保存...</div>
        </div>
    </div>
}