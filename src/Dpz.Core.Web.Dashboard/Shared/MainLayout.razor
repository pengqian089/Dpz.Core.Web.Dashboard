@using Dpz.Core.EnumLibrary
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Dpz.Core.Web.Dashboard.Shared.Components.Dialog
@inherits LayoutComponentBase

<div class="app-layout">
    <aside class="app-sidebar @(_drawerOpen ? "is-open" : "")">
        <div class="app-sidebar__header">
            <div class="app-sidebar__logo">
                <img src="https://dpangzi.com/core/images/Lara-Croft.png" alt="logo"/>
                <span>后台管理</span>
            </div>
        </div>
        <NavMenu />
    </aside>

    <!-- Overlay for Mobile -->
    <div class="app-overlay @(_drawerOpen ? "is-visible" : "")" @onclick="DrawerToggle"></div>

    <div class="app-main @(_drawerOpen ? "is-open" : "")">
        <header class="app-header">
            <div class="flex items-center gap-4">
                <button class="app-header__toggle btn-icon" @onclick="DrawerToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="app-header__title hidden-sm-down">
                    后台管理系统
                </div>
            </div>

            <div class="app-header__actions flex items-center gap-4" style="margin-left: auto;">
                 <div class="dropdown">
                    <button class="btn-icon">
                        <i class="fas fa-th"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="https://core.dpangzi.com" target="_blank" class="dropdown-item">
                            <i class="fas fa-server"></i> 核心站点
                        </a>
                        <a href="https://www.dpangzi.com" target="_blank" class="dropdown-item">
                            <i class="fas fa-globe"></i> 主站点
                        </a>
                        <a href="https://auth.dpangzi.com" target="_blank" class="dropdown-item">
                            <i class="fa-solid fa-podcast"></i> 认证中心
                        </a>
                        <div style="height: 1px; background: var(--border-color); margin: 4px 0;"></div>
                        <a href="https://pan.dpangzi.com" target="_blank" class="dropdown-item">
                            <i class="fa-solid fa-cloud"></i> 网盘
                        </a>
                        <a href="https://www.dpangzi.com" target="_blank" class="dropdown-item">
                            <i class="fa-solid fa-book"></i> 笔记
                        </a>
                        <a href="https://terminal.dpangzi.com" target="_blank" class="dropdown-item">
                            <i class="fa-solid fa-terminal"></i> 服务器终端管理
                        </a>
                        <a href="https://git.dpangzi.com" target="_blank" class="dropdown-item">
                            <i class="fa-brands fa-git"></i> git托管
                        </a>
                        <a href="https://www.dpangzi.com" target="_blank" class="dropdown-item">
                            <i class="fas fa-book"></i> 日志
                        </a>
                        <div style="height: 1px; background: var(--border-color); margin: 4px 0;"></div>
                        <a href="https://config.dpangzi.com" target="_blank" class="dropdown-item">
                            <i class="fas fa-cogs"></i> 配置中心
                        </a>
                    </div>
                </div>

                <a href="https://www.dpangzi.com" target="_blank" class="btn-icon" title="主站点">
                    <i class="fas fa-external-link-alt"></i>
                </a>

                <AuthorizeView>
                    <Authorized Context="auth">
                        <div class="dropdown">
                            <div class="user-profile flex items-center gap-2" style="cursor: pointer">
                                @{
                                    var avatar = auth.User.FindFirst("picture")?.Value;
                                }
                                @if (!string.IsNullOrWhiteSpace(avatar))
                                {
                                    <img src="@avatar" style="width: 32px; height: 32px; border-radius: 50%;" alt="Avatar"/>
                                }
                                else
                                {
                                    <i class="fas fa-user-circle fa-lg"></i>
                                }
                                <span class="text-sm">@auth.User.Identity?.Name</span>
                            </div>
                            <div class="dropdown-menu">
                                <button class="dropdown-item" @onclick="BeginLogout">
                                    <i class="fas fa-sign-out-alt"></i> 注销
                                </button>
                            </div>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                         @{
                            var returnUrl = Uri.EscapeDataString(Navigation.Uri);
                        }
                        <a href="@($"/authentication/login?returnUrl={returnUrl}")" class="btn btn-primary">登录</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="app-content">
            @Body
        </main>
    </div>

    <!-- Dialog Container for global dialogs/toasts/notifications -->
    <DialogContainer />
</div>
