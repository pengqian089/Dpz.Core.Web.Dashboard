@page "/"
@attribute [Authorize]

<div class="dashboard-hero">
    <div>
        <h1>内容运营总览</h1>
        <p>这里显示网站的核心数据指标和运营状态。</p>
    </div>
    <div class="flex gap-4 items-center">
        <span class="badge badge-secondary">数据最后更新: @_lastUpdated.ToString("yyyy-MM-dd HH:mm:ss")</span>
        <button class="btn btn-primary" @onclick="RefreshSummaryAsync">
            <i class="fas fa-sync-alt"></i> 刷新数据
        </button>
    </div>
</div>

<div class="dashboard-grid">
    <div class="stat-card">
        <div class="stat-card__icon stat-card__icon--primary">
            <i class="fas fa-bolt"></i>
        </div>
        <div class="stat-card__value">@FormatNumber(TodayAccessTotal)</div>
        <div class="stat-card__label">今日访问总量</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__icon stat-card__icon--warning">
            <i class="fas fa-chart-line"></i>
        </div>
        <div class="stat-card__value">@FormatNumber(WeekAverage)</div>
        <div class="stat-card__label">七日平均访问</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__icon stat-card__icon--success">
            <i class="fas fa-file-alt"></i>
        </div>
        <div class="stat-card__value">@FormatNumber(_summary?.TodayArticleCount ?? 0)</div>
        <div class="stat-card__label">今日发布文章</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__icon stat-card__icon--info">
            <i class="fas fa-images"></i>
        </div>
        <div class="stat-card__value">@FormatNumber(BannerCount)</div>
        <div class="stat-card__label">轮播图数量</div>
    </div>
</div>

<div class="content-grid">
     <div class="panel">
        <div class="panel-header">
             <div class="flex justify-between items-center w-100">
                <h3 class="panel-title">七日访问趋势</h3>
                <span class="badge badge-secondary">近7天</span>
            </div>
        </div>
        <div class="panel-body">
            @if (_isLoading)
            {
               <div class="flex items-center justify-center" style="height: 300px;">
                    <span class="text-muted">加载中...</span>
               </div>
            }
            else
            {
                 <div style="height: 300px; width: 100%;">
                    <canvas id="visitorChart"></canvas>
                </div>
            }
        </div>
    </div>

     <div class="panel">
        <div class="panel-header">
            <h3 class="panel-title">Banner 轮播</h3>
        </div>
        <div class="panel-body" style="padding: 0;">
             @if (_summary?.Banner != null && _summary.Banner.Count > 0)
            {
                <div id="bannerCarousel" class="carousel">
                    @foreach (var item in _summary.Banner)
                    {
                        <div class="carousel-slide">
                            <img src="@item.AccessUrl" alt="@item.Description" />
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <div class="carousel-caption">
                                    <h4>@item.Description</h4>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="flex items-center justify-center" style="height: 320px; background-color: rgba(0,0,0,0.2);">
                    <span class="text-muted">暂无 Banner 数据</span>
                </div>
            }
        </div>
    </div>
</div>

<div class="content-grid" style="margin-top: var(--spacing-lg);">
    <div class="panel">
        <div class="panel-header">
            <h3 class="panel-title">系统日志</h3>
        </div>
        <div class="panel-body" style="max-height: 300px;overflow-y: auto;">
            @if (!string.IsNullOrEmpty(_summary?.LatestLogs))
            {
                 <pre class="log-scroll log-content"><code class="language-bash">@_summary.LatestLogs</code></pre>
            }
            else
            {
                <div class="log-empty flex items-center justify-center">
                    暂无日志数据
                </div>
            }
        </div>
    </div>
    <div class="panel">
        <div class="panel-header">
             <div class="flex justify-between items-center w-100">
                <h3 class="panel-title">最新文章</h3>
            </div>
        </div>
        <div class="panel-body">
            @if (_summary?.LatestArticles != null)
            {
                <div class="list-group">
                @foreach (var item in _summary.LatestArticles)
                {
                    <a href="/article/edit/@item.Id" class="list-group-item">
                        <span class="text-truncate" style="max-width: 70%;">@item.Title</span>
                        <div class="flex items-center gap-2">
                             @if(item.ImagesAddress.Count > 0)
                            {
                                 <span class="badge badge-secondary"><i class="fas fa-image"></i> @item.ImagesAddress.Count</span>
                            }
                            <span class="text-sm text-muted">@item.CreateTime.ToString("MM-dd")</span>
                        </div>
                    </a>
                }
                </div>
            }
        </div>
    </div>
</div>
