<div class="auth-prompt">
    <div class="auth-prompt__icon">
        <i class="fas fa-lock"></i>
    </div>
    <h1 class="auth-prompt__title">@Message</h1>
    <p class="auth-prompt__description">@Description</p>
    
    <div class="auth-prompt__actions">
        <button class="btn-auth btn-auth--primary" @onclick="LoginNow">
            <i class="fas fa-sign-in-alt"></i>
            立即登录
        </button>
    </div>

    @if (_autoRedirect)
    {
        <div class="auth-prompt__auto-redirect">
            <div class="auth-prompt__countdown">
                将于 <span class="auth-prompt__countdown-number">@_seconds</span> 秒后自动跳转
            </div>
            <button class="btn-auth btn-auth--text" @onclick="CancelAuto">
                <i class="fas fa-times"></i>
                取消自动跳转
            </button>
        </div>
    }
</div>

