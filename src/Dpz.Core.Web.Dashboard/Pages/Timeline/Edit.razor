@page "/timeline/edit/{Id}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Forms
@using Dpz.Core.Web.Dashboard.Shared.Components
@if (_isLoading)
{
    <div class="timeline-form timeline-form--loading">
        <div class="timeline-form__skeleton">
            <div class="skeleton skeleton--text-lg"></div>
            <div class="skeleton skeleton--text"></div>
            <div class="skeleton skeleton--text"></div>
            <div class="skeleton skeleton--text"></div>
            <div class="skeleton skeleton--text-lg"></div>
            <div class="skeleton skeleton--card"></div>
        </div>
    </div>
}
else
{
    <div class="timeline-form">
        <div class="timeline-form__header">
            <h1 class="timeline-form__title">编辑时间轴</h1>
            <p class="timeline-form__description">更新节点内容，保持信息及时准确</p>
        </div>

        <EditForm Model="@_timeline" OnValidSubmit="PostDataAsync">
            <DataAnnotationsValidator/>
            <div class="timeline-form__content">
                <div class="timeline-form__section">
                    <div class="timeline-form__section-title">基础信息</div>
                    <div class="timeline-form__grid">
                        <div class="form-group">
                            <label class="form-label form-label--required">标题</label>
                            <input type="text"
                                   class="form-control"
                                   placeholder="请输入时间轴标题"
                                   @bind="_timeline.Title"
                                   @bind:event="oninput" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">链接</label>
                            <input type="text"
                                   class="form-control"
                                   placeholder="关联链接 (可选)"
                                   @bind="_timeline.More"
                                   @bind:event="oninput" />
                        </div>

                        <div class="form-group">
                            <label class="form-label form-label--required">时间节点</label>
                            <InputDate class="form-control"
                                       @bind-Value="_timeline.Date" />
                        </div>
                    </div>
                </div>

                <div class="timeline-form__section timeline-form__section--editor">
                    <div class="timeline-form__section-title">内容编辑</div>
                    <MarkdownEditor @ref="_editor"
                                    UploadAction="/api/Timeline/upload"
                                    Markdown="@_timeline.Content" />
                </div>

                <div class="timeline-form__validation">
                    <ValidationSummary/>
                </div>
            </div>

            <div class="timeline-form__actions">
                <button class="btn btn-secondary" type="button" @onclick="BackToList" disabled="@_isPublishing">
                    返回列表
                </button>
                <button class="btn btn-primary" type="submit" disabled="@_isPublishing">
                    @if (_isPublishing)
                    {
                        <span class="btn-loading">
                            <span class="btn-loading__spinner"></span>
                            保存中
                        </span>
                    }
                    else
                    {
                        <span>保存</span>
                    }
                </button>
            </div>
        </EditForm>
    </div>

    @if (_isPublishing)
    {
        <div class="timeline-form__loading-overlay">
            <div class="timeline-form__loading-content">
                <div class="timeline-form__loading-spinner"></div>
                <div class="timeline-form__loading-text">正在保存...</div>
            </div>
        </div>
    }
}