@page "/dynamic/edit/{*id}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Forms

@if (_isLoading)
{
    <div class="dynamic-form__skeleton">
        <div class="skeleton skeleton--title skeleton--half"></div>
        <div class="skeleton skeleton--input skeleton--full"></div>
        <div class="skeleton skeleton--input skeleton--full"></div>
        <div class="skeleton skeleton--editor skeleton--full"></div>
        <div class="dynamic-form__skeleton-actions">
            <div class="skeleton skeleton--button"></div>
            <div class="skeleton skeleton--button"></div>
        </div>
    </div>
}
else
{
    <div class="dynamic-form">
        <div class="dynamic-form__header">
            <h1 class="dynamic-form__title">修改动态页</h1>
            <p class="dynamic-form__description">更新活动页面内容，保持信息及时准确</p>
        </div>

        <EditForm Model="@_t" OnValidSubmit="PostDataAsync">
            <DataAnnotationsValidator/>
            <div class="dynamic-form__content">
                <div class="dynamic-form__section">
                    <div class="dynamic-form__section-title">基础信息</div>
                    <div class="dynamic-form__grid">
                        <div class="form-group">
                            <label class="form-label">页面名称</label>
                            <input type="text"
                                   class="form-control"
                                   value="@_name"
                                   readonly />
                        </div>
                        <div class="form-group">
                            <label class="form-label">访问地址</label>
                            <div class="dynamic-form__link">
                                <input type="text"
                                       class="form-control"
                                       value="@BuildPreviewUrl(_name)"
                                       readonly />
                                <a class="btn btn-secondary btn-sm"
                                   href="@BuildPreviewUrl(_name)"
                                   target="_blank"
                                   rel="noreferrer">
                                    预览
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="dynamic-form__section dynamic-form__section--editor">
                    <div class="dynamic-form__section-title">页面内容</div>
                    <div class="dynamic-form__editor">
                        <HtmlEditor @ref="_editor" Html="@_htmlContent.ToString()" />
                    </div>
                </div>

                <div class="dynamic-form__validation">
                    <ValidationSummary/>
                </div>
            </div>

            <div class="dynamic-form__actions">
                <button class="btn btn-secondary" type="button" @onclick="BackToList" disabled="@_isPublishing">
                    返回列表
                </button>
                <button class="btn btn-primary" type="submit" disabled="@_isPublishing">
                    @if (_isPublishing)
                    {
                        <span class="btn-loading">
                            <span class="btn-loading__spinner"></span>
                            发布中
                        </span>
                    }
                    else
                    {
                        <span>保存</span>
                    }
                </button>
            </div>
        </EditForm>
    </div>
}

@if (_isPublishing)
{
    <div class="dynamic-form__loading-overlay">
        <div class="dynamic-form__loading-content">
            <div class="dynamic-form__loading-spinner"></div>
            <div class="dynamic-form__loading-text">正在保存...</div>
        </div>
    </div>
}