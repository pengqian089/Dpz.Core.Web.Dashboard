@page "/music/detail/{Id}"
@attribute [Authorize]

<div class="music-form">
    <div class="music-form__header">
        <h1 class="music-form__title">音乐详情</h1>
        <p class="music-form__description">预览已上传的音乐素材，快速调整封面与歌词信息</p>
    </div>

    @if (_isLoading)
    {
        <div class="music-form__content">
            <div style="background-color: var(--bg-surface); border: 1px solid var(--border-color); border-radius: var(--border-radius); padding: var(--spacing-xl);">
                <div class="skeleton skeleton--text-lg" style="margin-bottom: var(--spacing-md);"></div>
                <div class="skeleton skeleton--text" style="margin-bottom: var(--spacing-md); width: 80%;"></div>
                <div class="skeleton skeleton--text" style="height: 160px; margin-bottom: var(--spacing-md);"></div>
                <div style="display: flex; gap: var(--spacing-md);">
                    <div class="skeleton skeleton--button"></div>
                    <div class="skeleton skeleton--button"></div>
                </div>
            </div>
        </div>
    }
    else
    {
        @if (_isPosting)
        {
            <div class="publishing-overlay">
                <div>
                    <div class="publishing-overlay__spinner"></div>
                    <p class="publishing-overlay__text">正在保存...</p>
                </div>
            </div>
        }

        <EditForm Model="_t" OnValidSubmit="PostInformationAsync">
            <DataAnnotationsValidator />
            
            <div class="music-form__content">
                <div class="music-form__main">
                    <!-- 音频信息区域 -->
                    <section class="form-section">
                        <div class="form-section__header">
                            <h3 class="form-section__title">音频信息</h3>
                            <p class="form-section__description">查看文件信息并试播音频</p>
                        </div>

                        @if (_selectMusic?.Any() == true)
                        {
                            <div class="file-info-display">
                                @foreach (var file in _selectMusic)
                                {
                                    <div class="file-info-display__item" key="@file.Key">
                                        <span class="file-info-display__badge">@(file.Key.Split(".").Last().ToUpperInvariant())</span>
                                        <span class="file-info-display__name">@file.Key</span>
                                        <span class="file-info-display__meta">@(file.Value.FileSize())</span>
                                    </div>
                                }
                            </div>
                        }

                        <div class="audio-preview">
                            <audio controls src="@_musicModel.MusicUrl" preload="metadata"></audio>
                        </div>
                    </section>

                    <!-- 封面图片区域 -->
                    <section class="form-section">
                        <div class="form-section__header">
                            <div>
                                <h3 class="form-section__title">封面图片</h3>
                                <p class="form-section__description">替换封面即可实时查看预览效果</p>
                            </div>
                            <label for="fileCover" class="btn btn-primary">
                                <i class="fas fa-cloud-upload-alt"></i>
                                更新封面
                            </label>
                        </div>

                        <InputFile OnChange="OnCoverChanged" id="fileCover" class="file-upload-zone__input" 
                                   accept="@(string.Join(',', AppTools.ImageExtensions.Select(x => '.' + x)))" />

                        <div class="form-hint" style="margin-bottom: var(--spacing-md);">
                            <i class="fas fa-info-circle"></i>
                            支持格式：@string.Join("、", AppTools.ImageExtensions.Select(x => x.ToUpperInvariant()))
                        </div>

                        @if (!string.IsNullOrEmpty(_musicModel.CoverUrl) && _showCover)
                        {
                            <div class="cover-preview" style="margin-bottom: var(--spacing-md);">
                                <img src="@_musicModel.CoverUrl" alt="当前封面" 
                                     style="max-width: 300px; border-radius: var(--border-radius); border: 1px solid var(--border-color);" />
                                <p style="color: var(--text-secondary); font-size: 0.875rem; margin-top: var(--spacing-sm);">当前封面</p>
                            </div>
                        }

                        @if (_selectCover.Any())
                        {
                            <div class="file-info-display">
                                @foreach (var file in _selectCover)
                                {
                                    <div class="file-info-display__item" key="@file.Key">
                                        <span class="file-info-display__badge file-info-display__badge--secondary">@(file.Key.Split(".").Last().ToUpperInvariant())</span>
                                        <span class="file-info-display__name">@file.Key</span>
                                        <span class="file-info-display__meta">@(file.Value.FileSize())</span>
                                    </div>
                                }
                            </div>
                        }
                    </section>

                    <!-- 歌词文件区域 -->
                    <section class="form-section">
                        <div class="form-section__header">
                            <div>
                                <h3 class="form-section__title">歌词文件</h3>
                                <p class="form-section__description">上传 .LRC 文件，自动刷新下方预览</p>
                            </div>
                            <label for="fileLrc" class="btn btn-primary">
                                <i class="fas fa-cloud-upload-alt"></i>
                                更新歌词
                            </label>
                        </div>

                        <InputFile OnChange="OnLrcChanged" id="fileLrc" class="file-upload-zone__input" accept=".lrc" />

                        @if (_selectLrc.Any())
                        {
                            <div class="file-info-display" style="margin-bottom: var(--spacing-md);">
                                @foreach (var file in _selectLrc)
                                {
                                    <div class="file-info-display__item" key="@file.Key">
                                        <span class="file-info-display__badge file-info-display__badge--info">@(file.Key.Split(".").Last().ToUpperInvariant())</span>
                                        <span class="file-info-display__name">@file.Key</span>
                                        <span class="file-info-display__meta">@(file.Value.FileSize())</span>
                                    </div>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_lrcContent))
                        {
                            <div class="lyric-preview">
                                <pre><code>@_lrcContent</code></pre>
                            </div>
                        }
                    </section>

                    <!-- 分组管理区域 -->
                    <section class="form-section">
                        <div class="form-section__header">
                            <h3 class="form-section__title">分类与标签</h3>
                            <p class="form-section__description">调整分组或新增标签便于检索</p>
                        </div>

                        <div class="tag-selector">
                            @foreach (var group in _groups)
                            {
                                <button type="button" 
                                        class="tag-selector__item @(_selectedGroups.Contains(group) ? "tag-selector__item--active" : "")"
                                        @onclick="() => ToggleGroup(group)">
                                    <i class="fas @(_selectedGroups.Contains(group) ? "fa-check-circle" : "fa-circle")"></i>
                                    @group
                                </button>
                            }
                        </div>

                        <div class="form-group" style="margin-top: var(--spacing-md);">
                            <label class="form-label">添加新分组</label>
                            <div style="display: flex; gap: var(--spacing-sm);">
                                <input type="text" 
                                       class="form-control" 
                                       placeholder="输入新的分组名称" 
                                       @bind="_addGroup"
                                       @onkeydown="HandleAddGroupKeyDown"
                                       @onkeydown:preventDefault="@_preventDefault" />
                                <button type="button" class="btn btn-primary" @onclick="AddNewGroup">
                                    <i class="fas fa-plus"></i>
                                    添加
                                </button>
                            </div>
                        </div>
                    </section>
                </div>
            </div>

            <div class="music-form__actions">
                <button type="submit" class="btn btn-primary" disabled="@_isPosting">
                    @if (_isPosting)
                    {
                        <span class="btn-loading">
                            <span class="btn-loading__spinner"></span>
                            <span>正在保存</span>
                        </span>
                    }
                    else
                    {
                        <i class="fas fa-save"></i>
                        <span>保存修改</span>
                    }
                </button>
                <button type="button" class="btn btn-secondary" @onclick='() => navigation.NavigateTo("/music")'>
                    <i class="fas fa-arrow-left"></i>
                    返回列表
                </button>
            </div>
        </EditForm>
    }
</div>
 