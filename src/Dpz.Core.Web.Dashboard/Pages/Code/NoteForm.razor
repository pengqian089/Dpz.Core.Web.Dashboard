<div class="code-note">
    <div class="code-note__header">
        <div>
            <div class="code-note__title">保存说明</div>
            <div class="code-note__subtitle">为目录或文件补充简要描述</div>
        </div>
        <div class="code-note__icon">
            <i class="fas fa-sticky-note"></i>
        </div>
    </div>

    <div class="code-note__body">
        <div class="code-note__meta">
            <div class="code-note__meta-item">
                <span class="code-note__meta-label">路径</span>
                <span class="code-note__meta-value">@DisplayPath</span>
            </div>
            <div class="code-note__meta-item">
                <span class="code-note__meta-label">名称</span>
                <span class="code-note__meta-value">@Model.Name</span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">说明</label>
            <textarea class="form-control code-note__textarea"
                      rows="4"
                      placeholder="输入目录或文件的说明"
                      @bind="_note"
                      @bind:event="oninput"></textarea>
            <div class="code-note__hint">支持留空以清除已有说明</div>
        </div>
    </div>

    <div class="code-note__footer">
        <button class="btn btn-secondary" @onclick="Cancel" disabled="@_isSubmitting">取消</button>
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_isSubmitting">
            @if (_isSubmitting)
            {
                <span class="btn-loading">
                    <span class="btn-loading__spinner"></span>
                    保存中
                </span>
            }
            else
            {
                <span>保存</span>
            }
        </button>
    </div>
</div>