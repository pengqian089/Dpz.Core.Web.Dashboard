@using BlazorMonaco.Editor
@page "/code"
@attribute [Authorize]

<div class="code-page">
    <div class="code-page__header">
        <h1 class="page-title">
            <i class="fas fa-code"></i>
            代码管理
        </h1>
        <p class="page-description">浏览站点源码并维护说明信息</p>
    </div>

    <div class="code-page__toolbar">
        <div class="code-page__toolbar-left">
            <button class="btn btn-secondary" @onclick="BackToRoot" disabled="@_isLoading">
                <i class="fas fa-home"></i>
                根目录
            </button>
            <button class="btn-icon" title="刷新" @onclick="Reload" disabled="@_isLoading">
                <i class="fas fa-sync-alt @(_isLoading ? "fa-spin" : "")"></i>
            </button>
        </div>
        <div class="code-page__toolbar-right">
            <div class="code-page__search">
                <input type="text" class="form-control" placeholder="搜索文件或目录" @bind="_searchWord" @bind:event="oninput"
                    @onkeydown="HandleSearchKeyDown" />
                <button class="btn btn-primary" @onclick="Search" disabled="@_isLoading">
                    <i class="fas fa-search"></i>
                    搜索
                </button>
            </div>
            <div class="code-page__summary">
                <span class="code-page__summary-label">共</span>
                <span class="code-page__summary-value">@TotalItems</span>
                <span class="code-page__summary-label">项</span>
            </div>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="code-skeleton">
            <div class="code-skeleton__table">
                @for (var i = 0; i < 8; i++)
                {
                    <div class="code-skeleton__row">
                        <div class="skeleton skeleton--text-lg"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--text"></div>
                        <div class="skeleton skeleton--button"></div>
                    </div>
                }
            </div>
        </div>
    }
    else if (_treeData == null || IsUnavailable)
    {
        <div class="code-page__empty">
            <i class="fas fa-ban"></i>
            <p>@UnavailableMessage</p>
        </div>
    }
    else
    {
        @if (!_treeData.IsRoot)
        {
            <div class="code-breadcrumb">
                <button class="code-link" type="button" @onclick="BackToRoot">
                    根目录
                </button>
                @for (var i = 0; i < _treeData.CurrentPaths.Count; i++)
                {
                    <span class="code-breadcrumb__sep">/</span>
                    @if (i == _treeData.CurrentPaths.Count - 1)
                    {
                        <span class="code-breadcrumb__current">@_treeData.CurrentPaths[i]</span>
                    }
                    else
                    {
                        var path = _treeData.CurrentPaths.Take(i + 1).ToArray();
                        <button class="code-link" type="button" @onclick="() => LoadTreeDataAsync(path)">
                            @_treeData.CurrentPaths[i]
                        </button>
                    }
                }
            </div>
        }

        if (_treeData.IsDirectory)
        {
            <div class="code-table">
                <div class="code-table__wrapper">
                    <table>
                        <thead>
                        <tr>
                            <th>名称</th>
                            <th>说明</th>
                            <th>更新时间</th>
                            <th>操作</th>
                        </tr>
                        </thead>
                        <tbody>
                        @if (!_treeData.Directories.Any() && !_treeData.Files.Any())
                        {
                            <tr>
                                <td colspan="4">
                                    <div class="code-table__empty">
                                        当前目录为空
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in _treeData.Directories)
                            {
                                <tr>
                                    <td data-label="名称">
                                        <div class="code-table__name">
                                            <i class="fas fa-folder"></i>
                                            <button class="code-table__link" type="button"
                                                    title="@string.Join('/', item.CurrentPath)"
                                                    @onclick="() => LoadTreeDataAsync(item.CurrentPath)">
                                                <HighLight SearchWord="@_searchWord" ItemName="@item.Name" />
                                            </button>
                                            <span class="code-table__tag">目录</span>
                                        </div>
                                    </td>
                                    <td data-label="说明">
                                        <span class="code-table__note">@GetNoteText(item.Note)</span>
                                    </td>
                                    <td data-label="更新时间">
                                        <span class="code-table__time">
                                            @item.LastUpdateTime.ToString("yyyy-MM-dd HH:mm:ss")
                                        </span>
                                    </td>
                                    <td data-label="操作">
                                        <div class="code-table__actions">
                                            <button class="btn btn-secondary btn-sm"
                                                    @onclick="() => LoadTreeDataAsync(item.CurrentPath)">
                                                进入
                                            </button>
                                            <button class="btn btn-primary btn-sm"
                                                    @onclick="() => SaveNoteAsync(_treeData.CurrentPaths, item.Name, item.Note)">
                                                @(string.IsNullOrWhiteSpace(item.Note) ? "添加说明" : "修改说明")
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }

                            @foreach (var item in _treeData.Files)
                            {
                                <tr>
                                    <td data-label="名称">
                                        <div class="code-table__name">
                                            <i class="fas fa-file-code"></i>
                                            <button class="code-table__link" type="button"
                                                    title="@string.Join('/', item.CurrentPath)"
                                                    @onclick="() => LoadTreeDataAsync(item.CurrentPath)">
                                                <HighLight SearchWord="@_searchWord" ItemName="@item.Name" />
                                            </button>
                                            <span class="code-table__tag code-table__tag--file">文件</span>
                                        </div>
                                    </td>
                                    <td data-label="说明">
                                        <span class="code-table__note">@GetNoteText(item.Note)</span>
                                    </td>
                                    <td data-label="更新时间">
                                        <span class="code-table__time">
                                            @item.LastUpdateTime.ToString("yyyy-MM-dd HH:mm:ss")
                                        </span>
                                    </td>
                                    <td data-label="操作">
                                        <div class="code-table__actions">
                                            <button class="btn btn-secondary btn-sm"
                                                    @onclick="() => LoadTreeDataAsync(item.CurrentPath)">
                                                查看
                                            </button>
                                            <button class="btn btn-primary btn-sm"
                                                    @onclick="() => SaveNoteAsync(_treeData.CurrentPaths, item.Name, item.Note)">
                                                @(string.IsNullOrWhiteSpace(item.Note) ? "添加说明" : "修改说明")
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
            
            if (!string.IsNullOrWhiteSpace(_treeData.ReadmeContent))
            {
                <div class="code-readme">
                    <div class="code-readme__header">
                        <i class="fas fa-book-open"></i>
                        README
                    </div>
                    <MarkdownPreview Markdown="@_treeData.ReadmeContent" />
                </div>
            }
        }
        else
        {
            <div class="code-view">
                <div class="code-view__header">
                    <div>
                        <div class="code-view__title">@GetFileDisplayName()</div>
                        <div class="code-view__meta">
                            <span class="code-view__meta-item">
                                <i class="fas fa-folder-open"></i>
                                @string.Join("/", _treeData.CurrentPaths)
                            </span>
                            @if (!string.IsNullOrWhiteSpace(_treeData.CodeContainer?.Language))
                            {
                                <span class="code-view__badge">
                                    @_treeData.CodeContainer.Language
                                </span>
                            }
                        </div>
                    </div>
                    <div class="code-view__actions">
                        <button class="btn btn-secondary btn-sm" @onclick="BackToParent">
                            返回上级
                        </button>
                        <button class="btn btn-primary btn-sm" @onclick="EditCurrentNote">
                            编辑说明
                        </button>
                    </div>
                </div>

                <div class="code-view__body">
                    @if (_treeData.CodeContainer == null || string.IsNullOrWhiteSpace(_treeData.CodeContainer.CodeContent))
                    {
                        <div class="code-view__empty">暂无代码内容</div>
                    }
                    else if (!_treeData.CodeContainer.IsPreview)
                    {
                        <div class="code-view__empty">该文件不支持预览</div>
                    }
                    else if (string.IsNullOrWhiteSpace(_treeData.CodeContainer.Language))
                    {
                        <pre class="code-view__plain"><code>@_treeData.CodeContainer.CodeContent</code></pre>
                    }
                    else
                    {
                        <StandaloneCodeEditor CssClass="code-view-editor" Id="@EditorId"
                            ConstructionOptions="x => x.EditorConstructionOptions(_treeData.CodeContainer.Language, _treeData.CodeContainer.CodeContent, true)" />
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(_treeData.CodeContainer?.AiAnalyzeResult))
                {
                    <div class="code-view__analysis">
                        <div class="code-view__analysis-title">
                            <i class="fas fa-robot"></i>
                            AI 分析
                        </div>
                        <MarkdownPreview Markdown="@_treeData.CodeContainer.AiAnalyzeResult" />
                    </div>
                }
            </div>
        }
    }
</div>